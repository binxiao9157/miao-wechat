index 64dc307..3786775 100644
--- a/.env.example
+++ b/.env.example
@@ -3,6 +3,17 @@ DATABASE_URL="file:./dev.db"
 JWT_SECRET="YOUR_SUPER_SECRET_KEY"
 TEST_SMS_CODE="888888"
 
+# ===== 短信服务（腾讯云 SMS）=====
+# SMS_ENABLED=false 时使用模拟模式（验证码仅打印到控制台，万能码可用）
+# SMS_ENABLED=true 时真实发送短信，万能码失效
+SMS_ENABLED="false"
+SMS_SECRET_ID="YOUR_SECRET_ID"
+SMS_SECRET_KEY="YOUR_SECRET_KEY"
+SMS_SDK_APP_ID="1400xxxxxx"
+SMS_SIGN_NAME="Miao喵伴"
+SMS_TEMPLATE_ID="12345678"
+SMS_REGION="ap-guangzhou"
+
 # ===== Gemini（可选）=====
 GEMINI_API_KEY="MY_GEMINI_API_KEY"
 
