===================================================================
Fix #8: TimeLetters keep-alive 路由激活时刷新信件列表
问题：keep-alive 下组件不重新挂载，useEffect([]) 只执行一次。
     外部数据变更（如通知页操作）后切回时光信件页看到旧数据。
方案：与 Fix #1 同理，useEffect 监听 location.pathname，
     路由匹配时 setLetters(storage.getTimeLetters())。
===================================================================

--- a/src/pages/TimeLetters.tsx
+++ b/src/pages/TimeLetters.tsx
@@ -1,4 +1,5 @@
 import { useState, useEffect } from "react";
+import { useLocation } from "react-router-dom";
 import { Plus, Lock, Unlock, ArrowLeft, Calendar, Send, Clock, ChevronRight } from "lucide-react";

@@ -9,14 +10,16 @@
 export default function TimeLetters() {
+  const location = useLocation();
   const [letters, setLetters] = useState<TimeLetter[]>(() => storage.getTimeLetters());
   ...

-  useEffect(() => {
-    setLetters(storage.getTimeLetters());
-  }, []);
+  // keep-alive：路由激活时静默刷新数据
+  useEffect(() => {
+    if (location.pathname === '/time-letters') {
+      setLetters(storage.getTimeLetters());
+    }
+  }, [location.pathname]);
