+function lazyRetry(importFn: () => Promise<{ default: React.ComponentType<any> }>) {
+  return lazy(async () => {
+    try {
+      return await importFn();
+    } catch (error) {
+      console.warn('Chunk load failed, retrying...', error);
+      await new Promise(r => setTimeout(r, 1000));
+      return importFn();
+    }
+  });
+}
