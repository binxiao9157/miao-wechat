# 阿里灵积 (DashScope) 配置
# 在 AI Studio 开发环境中，这些变量可以通过系统设置或 .env 文件提供
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
DASHSCOPE_IMAGE_MODEL=qwen-image-2.0
DASHSCOPE_VIDEO_MODEL=wan2.2-i2v-flash

# AliCloud AccessKey (如果需要原始 OSS 或其他服务)
ALICLOUD_AK_ID=your_alicloud_ak_id_here
ALICLOUD_AK_SECRET=your_alicloud_ak_secret_here

# 调试模式 (本地 Mock) - 设置为 true 则不调用真实 API
VITE_DASHSCOPE_MOCK_MODE=false
